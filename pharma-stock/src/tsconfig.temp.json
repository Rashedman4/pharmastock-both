{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "components/program/ElitePlanPage.tsx",
    "components/program/ElitePortfolioPage.tsx",
    "components/program/AdminInvestorDetailPage.tsx",
    "components/program/EliteDashboardPage.tsx",
    "modules/program/program.service.ts",
    "app/api/elite/closures/route.ts",
    "app/api/uploads/evidence/route.ts",
    "app/api/elite/payout-request/route.ts",
    "app/api/elite/firm-profit-payment/route.ts",
    "app/api/admin/elite-portfolios/[memberId]/payout-request/route.ts",
    "lib/evidence-upload.ts",
    "lib/evidence-security.ts",
    "app/api/elite/firm-profit-payment/[paymentId]/proof/route.ts",
    "app/api/admin/firm-bank-accounts/route.ts",
    "app/api/admin/firm-profit-payments/route.ts",
    "app/api/admin/firm-profit-payments/[paymentId]/review/route.ts",
    "app/admin/bank-settings/page.tsx",
    "app/admin/firm-profit-payments/page.tsx"
  ]
}
