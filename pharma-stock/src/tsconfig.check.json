{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "components/program/AdminInvestorsPage.tsx",
    "components/program/AdminInvestorDetailPage.tsx",
    "components/program/ElitePortfolioPage.tsx",
    "components/program/PublicElitePage.tsx",
    "components/program/shared.tsx",
    "modules/program/program.service.ts",
    "app/api/elite/closures/route.ts",
    "app/api/elite/status/route.ts",
    "app/api/admin/elite-portfolios/[memberId]/force-open/route.ts",
    "app/api/admin/positions/[positionId]/force-close/route.ts",
    "app/api/admin/manual-elite-members/route.ts",
    "app/api/admin/elite-applications/route.ts",
    "lib/evidence-upload.ts",
    "lib/evidence-security.ts",
    "lib/db.ts",
    "lib/stripe.ts",
    "modules/program/route-helpers.ts",
    "modules/program/price-cache.service.ts",
    "modules/market-data/financial-modeling-prep.provider.ts",
    "app/api/elite/firm-profit-payment/[paymentId]/proof/route.ts",
    "app/api/admin/firm-bank-accounts/route.ts",
    "app/api/admin/firm-profit-payments/route.ts",
    "app/api/admin/firm-profit-payments/[paymentId]/review/route.ts",
    "app/admin/bank-settings/page.tsx",
    "app/admin/firm-profit-payments/page.tsx",
    "app/api/uploads/evidence/route.ts"
  ]
}
